# Environment variables for Mechanic's Best Friend
GITHUB_OWNER=BrianLovegrove
GITHUB_REPO=Mechanics-Best-Friend
GITHUB_BRANCH=main
GITHUB_TOKEN=your_github_token_here

# Git SSH Configuration (for SSH-based uploads)
GIT_REPO=git@github.com:BrianLovegrove/Mechanics-Best-Friend.git
GIT_BRANCH=main
GIT_AUTHOR_NAME=MBF Upload Bot
GIT_AUTHOR_EMAIL=uploads@mechanicsbestfriend.app
GIT_SSH_PRIVATE_KEY_PATH=/path/to/ssh/key
# Windows example: C:\Users\username\.ssh\id_ed25519
# Linux example: /home/username/.ssh/id_ed25519

# Session configuration
SESSION_SECRET=mechanics_best_friend_secret_key_change_in_production
PORT=3000