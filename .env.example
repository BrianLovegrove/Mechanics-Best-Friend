# Environment variables for Mechanic's Best Friend
GITHUB_OWNER=BrianLovegrove
GITHUB_REPO=Mechanics-Best-Friend
GITHUB_BRANCH=main
# GITHUB_TOKEN=your_github_personal_access_token_here
# To enable GitHub repository uploads instead of local storage, 
# set GITHUB_TOKEN to a valid GitHub Personal Access Token with repository write permissions

# Git SSH Configuration (for SSH-based uploads)
GIT_REPO=git@github.com:BrianLovegrove/Mechanics-Best-Friend.git
GIT_BRANCH=Base
GIT_AUTHOR_NAME=MBF Upload Bot
GIT_AUTHOR_EMAIL=uploads@mechanicsbestfriend.app
GIT_SSH_PRIVATE_KEY_PATH=C:\Users\cmept\.ssh\id_ed25519
# Windows example: C:\Users\username\.ssh\id_ed25519
# Linux example: /home/username/.ssh/id_ed25519

# Session configuration
SESSION_SECRET=mechanics_best_friend_secret_key_change_in_production
PORT=3000

# IMPORTANT: To enable admin uploads to GitHub repository instead of local storage:
# 1. Create a GitHub Personal Access Token at https://github.com/settings/tokens
# 2. Give it "repo" permissions for the target repository
# 3. Set GITHUB_TOKEN=your_token_here
# 4. Restart the application